<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MyApplication" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="android:windowBackground">@color/light_bg</item>
        <item name="colorPrimary">@color/light_button_op</item>
    </style>

    <style name="Theme.MyApplication" parent="Base.Theme.MyApplication" />

    <!-- Style cho nút số chung -->
    <style name="Widget.App.Button.Circular" parent="Widget.Material3.Button">
        <item name="android:layout_width">72dp</item>
        <item name="android:layout_height">72dp</item>
        <item name="android:layout_margin">8dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="cornerRadius">42dp</item>
        <item name="backgroundTint">@color/light_button_num</item>
        <item name="android:textColor">@color/light_text_primary</item>
        <item name="android:padding">0dp</item>
        <item name="android:textSize">30sp</item>
    </style>
</resources>